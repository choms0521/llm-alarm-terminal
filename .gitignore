# Xcode build artifacts
build/
DerivedData/
*.xcarchive
*.app
*.dSYM
*.ipa

# Xcode user-specific
xcuserdata/
*.xcuserdata
*.xcuserdatad
*.xccheckout

# SwiftPM
.build/
.swiftpm/
Package.resolved
.netrc

# Generated by xcodegen (regenerated from project.yml)
ClaudeAlarmTerminal.xcodeproj/

# macOS metadata
.DS_Store

# OMC state (working state only; final artifacts go under docs/)
.omc/state/
.omc/sessions/
.omc/notepad.md
.omc/logs/
.omc/plans/*.tmp.md
.claude/

# Vendored Ghostty sources (re-fetch via scripts/bootstrap-ghostty.sh).
# The whole vendor/ tree is excluded because Zig build artifacts and
# downloaded dependencies push the working tree to several GB.
vendor/

# Pre-built libghostty XCFramework (regenerated by scripts/build-libghostty.sh).
Frameworks/

# Local secrets and credentials
.env
.env.local
*.p8
*.p12
*.cer
*.mobileprovision
